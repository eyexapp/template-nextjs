{
  "name": "nextjs",
  "displayName": "Next.js",
  "description": "Next.js 16 fullstack application with App Router, Zustand state management, and Tailwind CSS 4",
  "category": "fullstack",
  "language": "typescript",
  "framework": "nextjs",
  "stack": ["nextjs-16", "react-19", "typescript", "tailwindcss-4", "zustand", "next-intl", "playwright"],
  "features": ["app-router", "server-components", "server-actions", "i18n", "seo", "testing", "responsive"],
  "commands": {
    "dev": "npm run dev",
    "build": "npm run build",
    "test": "npm test",
    "lint": "npm run lint"
  },
  "packageManager": "npm",
  "ci": {
    "workflowTemplate": "nextjs",
    "runner": "ubuntu-latest",
    "runtime": {
      "name": "node",
      "version": "20",
      "setup": "actions/setup-node@v4",
      "cache": "npm"
    },
    "services": {},
    "steps": {
      "install": "npm ci",
      "build": "npm run build",
      "test": "npm test",
      "lint": "npm run lint"
    }
  }
}
